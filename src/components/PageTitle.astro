---
import type { Props } from '@astrojs/starlight/props';
import Default from '@astrojs/starlight/components/PageTitle.astro';
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

const { entry } = Astro.locals.starlightRoute;
const { title, titleImage, titleImageAlt, rarity, role } = entry.data;

import rarity_legendary from '../assets/characters/rarity_legendary.png';
import rarity_epic from '../assets/characters/rarity_epic.png';
import rarity_rare from '../assets/characters/rarity_rare.png';
import rarity_common from '../assets/characters/rarity_common.png';
import role_breaker from '../assets/characters/role_breaker.png';
import role_seeker from '../assets/characters/role_seeker.png';
import role_defender from '../assets/characters/role_defender.png';
import role_destroyer from '../assets/characters/role_destroyer.png';
import role_watcher from '../assets/characters/role_watcher.png';
---
{ titleImage && <Image src={titleImage} alt={titleImageAlt} height="64" class="float-right" /> }
{ role && role === 'Breaker' && <Image src={role_breaker} alt={role} height="30" class="float-right" /> }
{ role && role === 'Seeker' && <Image src={role_seeker} alt={role} height="30" class="float-right" /> }
{ role && role === 'Defender' && <Image src={role_defender} alt={role} height="30" class="float-right" /> }
{ role && role === 'Destroyer' && <Image src={role_destroyer} alt={role} height="30" class="float-right" /> }
{ role && role === 'Watcher' && <Image src={role_watcher} alt={role} height="30" class="float-right" /> }
{ rarity && rarity === 'Legendary' && <Image src={rarity_legendary} alt={rarity} height="30" class="float-right" /> }
{ rarity && rarity === 'Epic' && <Image src={rarity_epic} alt={rarity} height="30" class="float-right" /> }
{ rarity && rarity === 'Rare' && <Image src={rarity_rare} alt={rarity} height="30" class="float-right" /> }
{ rarity && rarity === 'Common' && <Image src={rarity_common} alt={rarity} height="30" class="float-right" /> }
<Default {...Astro.props}>
  <slot />
</Default>
