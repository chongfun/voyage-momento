---
const props = Astro.props;

import ImageCard from '../../ImageCard.astro';
import icon from '../../../assets/inventory/trinket/Spring Tonic.png'
---

<ImageCard image={icon} title="Spring Tonic">
<p>[<span class="text-yellow-500">Instant</span>]. Heals <span class="text-green-500">30</span>-<span class="text-green-500">45%</span> HP. Can be used up to <span class="text-orange-500">1</span> time per battle.</p>
</ImageCard>
