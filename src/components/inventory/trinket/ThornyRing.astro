---
const props = Astro.props;

import ImageCard from '../../ImageCard.astro';
import icon from '../../../assets/inventory/trinket/Thorny Ring.png'
---

<ImageCard image={icon} title="Thorny Ring">
<p>When [<span class="text-yellow-500">Injured</span>], increases ATK by <span class="text-orange-500">6</span>-<span class="text-orange-500">12%</span>.</p>
</ImageCard>
