---
const props = Astro.props;

import ImageCard from '../../ImageCard.astro';
import icon from '../../../assets/inventory/trinket/Berserk Incense.png'
---

<ImageCard image={icon} title="Berserk Incense">
<p>Gains [<span class="text-yellow-500">Berserk Awake</span>]. Effect: Increases Movement by <span class="text-orange-500">1</span> tile and DMG by <span class="text-orange-500">10</span>-<span class="text-orange-500">20%</span> for <span class="text-orange-500">2</span> turns. CD: <span class="text-orange-500">3</span> turns. Can be used up to <span class="text-orange-500">1</span>-<span class="text-orange-500">2</span> times per battle. CD: <span class="text-orange-500">5</span>-<span class="text-orange-500">3</span> turns.</p>
</ImageCard>
