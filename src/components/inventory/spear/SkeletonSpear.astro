---
const props = Astro.props;

import ImageCard from '../../ImageCard.astro';
import icon from '../../../assets/inventory/spear/Skeleton Spear.png'
---

<ImageCard image={icon} title="Skeleton Spear">
<p>Increases P.ATK by <span class="text-orange-500">2</span>-<span class="text-orange-500">10%</span>. Before initiating a single-target active attack, additionally deals [<span class="text-yellow-500">Piercing DMG</span>] equal to <span class="text-orange-500">10%</span> P.ATK to the target.</p>
</ImageCard>
