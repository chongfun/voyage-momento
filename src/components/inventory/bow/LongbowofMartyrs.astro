---
const props = Astro.props;

import ImageCard from '../../ImageCard.astro';
import icon from '../../../assets/inventory/bow/Longbow of Martyrs.png'
---

<ImageCard image={icon} title="Longbow of Martyrs">
<p>Increases P.ATK by <span class="text-orange-500">2</span>-<span class="text-orange-500">10%</span>. After Single-target Active Attack deals DMG, inflicts [<span class="text-yellow-500">Longbow of Martyrs</span>] for 1 turn.</p>
</ImageCard>
